{
  "name": "sql-front-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 9000",
    "build": "next build",
    "start": "next start -p 9000",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "docker:clean": "docker rm -f $(docker ps -a -q --filter ancestor=sql-front-frontend) 2>/dev/null || true && docker rmi -f $(docker images -q sql-front-frontend) 2>/dev/null || true",
    "docker:build": "docker build -t sql-front-frontend .",
    "docker:run": "docker run --rm --name frontend -p 9000:9000 sql-front-frontend"
  },
  "dependencies": {
    "@codemirror/lang-sql": "^6.10.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@types/react-redux": "^7.1.34",
    "@uiw/react-codemirror": "^4.25.3",
    "@xyflow/react": "^12.10.0",
    "axios": "^1.13.4",
    "next": "15.5.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.66.0",
    "react-hot-toast": "^2.6.0",
    "react-redux": "^9.2.0",
    "sass": "^1.93.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "classnames": "^2.5.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "prettier": "^3.6.2",
    "typescript": "^5"
  }
}
